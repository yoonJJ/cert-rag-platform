DATABASE_URL="postgresql://user:password@localhost:5432/certdb"
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_API_KEY="ollama"
REDIS_URL="redis://localhost:6379"
PORT=3001

# 기본 선택 옵션 ID (형식: ollama/모델명 또는 openai/모델명). 생략 시 첫 Ollama 항목
# 레거시: 모델명만 적으면 Ollama로 간주 (예: gpt-oss:20b)
# CHAT_MODEL=ollama/gpt-oss:20b

# Ollama 채팅 후보 (쉼표 구분, "모델id|표시이름")
# OLLAMA_CHAT_MODELS=gpt-oss:20b|GPT-OSS 20B,gemma4:26b|Gemma 4 26B

# OpenAI API — 서버 기동 시 키를 넣으면 재시작 전까지 유효 (대시보드 저장과 동일 메모리)
# OPENAI_API_KEY=sk-...

# OpenAI 채팅 후보 (쉼표 구분, "모델id|표시이름". 생략 시 gpt-4o / mini / turbo)
# OPENAI_CHAT_MODELS=gpt-4o|GPT-4o,gpt-4o-mini|4o mini

# Gemini API (선택)
# GEMINI_API_KEY=AIza...
# GEMINI_CHAT_MODELS=gemini-2.0-flash|Gemini 2.0 Flash (프리티어),gemini-1.5-pro|Gemini 1.5 Pro

# Claude API (선택)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_CHAT_MODELS=claude-3-5-haiku-latest|Claude 3.5 Haiku,claude-3-5-sonnet-latest|Claude 3.5 Sonnet
